{
  "name": "@parcellab/promise-ui",
  "version": "0.1.0",
  "description": "Embeddable delivery promise widget for retailer product and checkout pages. Displays estimated delivery dates, courier options, and order cutoff urgency powered by the parcelLab Promise API.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/parcelLab/parcellab-embedded-ui-snippets.git",
    "directory": "packages/promise-ui"
  },
  "homepage": "https://parcellab.github.io/parcellab-embedded-ui-snippets/promise-ui/",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/promise.esm.js",
      "default": "./dist/promise.iife.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && node scripts/build.mjs && tsc -p tsconfig.types.json",
    "build:site": "node scripts/build-site.mjs",
    "dev": "node scripts/dev.mjs",
    "test": "vitest run --environment jsdom"
  },
  "devDependencies": {
    "esbuild": "^0.25.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
